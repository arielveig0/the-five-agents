# The Five Agents — environment template
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# How these get loaded:
#   The .mcp.json config references ${GEMINI_API_KEY} / ${IMAGE_OUTPUT_DIR}.
#   Claude Code reads them from the SHELL that launches it. Two options:
#     1. Export them in your shell before running `claude`:
#        PowerShell: $env:GEMINI_API_KEY = "..."; $env:IMAGE_OUTPUT_DIR = "..."
#        bash:       export GEMINI_API_KEY=... ; export IMAGE_OUTPUT_DIR=...
#     2. Use a dotenv loader / direnv to auto-export this file when you cd here.
#   The mcp-image MCP server itself (Node.js) also reads .env from its CWD,
#   so just having .env in the project root is usually enough.

# Google AI Studio key — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Absolute path where generated images land. Should point at this project's outputs/.
IMAGE_OUTPUT_DIR=c:\Users\ariel\Desktop\Workspace\the-five-agents\outputs

# Optional: fast | balanced | quality   (default already set in .mcp.json)
# IMAGE_QUALITY=balanced

# Optional: set to "true" to disable mcp-image's automatic prompt enhancement
# SKIP_PROMPT_ENHANCEMENT=false
